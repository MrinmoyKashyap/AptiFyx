generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  address   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]
}

model Provider {
  id                String   @id @default(uuid())
  name              String
  phone             String   @unique
  address           String?
  latitude          Float?
  longitude         Float?
  services          String   // JSON array of service slugs
  isOnline          Boolean  @default(false)
  rating            Float    @default(5.0)
  totalJobsDone     Int      @default(0)
  pendingCommission Float    @default(0.0)
  unpaidJobCount    Int      @default(0)
  socketId          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  jobs        Job[]
  commissions Commission[]
}

model Job {
  id               String   @id @default(uuid())
  customerId       String
  providerId       String?
  serviceSlug      String
  serviceName      String
  status           String   @default("broadcasting")
  startOtp         String?
  latitude         Float
  longitude        Float
  address          String?
  customerSocketId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User      @relation(fields: [customerId], references: [id])
  provider Provider? @relation(fields: [providerId], references: [id])
}

model Commission {
  id         String    @id @default(uuid())
  providerId String
  jobId      String?
  amount     Float
  status     String    @default("pending")
  paidAt     DateTime?
  createdAt  DateTime  @default(now())

  provider Provider @relation(fields: [providerId], references: [id])
}

model OtpRecord {
  id        String   @id @default(uuid())
  phone     String
  code      String
  role      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
